{
  "manifest_version": 3,
  "name": "xstamped",
  "version": "0.2.0",
  "description": "Capture X posts as customizable PNGs.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": [
        "vendor/html-to-image.min.js",
        "overlay/templates.js",
        "overlay/card.js",
        "overlay/extract.js",
        "overlay/render.js",
        "overlay/capture.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": [
    "https://pbs.twimg.com/*",
    "https://video.twimg.com/*",
    "https://abs.twimg.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["overlay/overlay.css", "vendor/fonts/Inter.woff2"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
